<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEW POINT - نظام الحسابات والمهام</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Segoe UI',Tahoma,sans-serif;background:#0f1923;min-height:100vh;direction:rtl;color:#333}
.header{background:linear-gradient(135deg,#0f3460,#533483);color:white;padding:15px 20px;position:sticky;top:0;z-index:100}
.header h1{font-size:18px;margin-bottom:2px}
.header p{font-size:11px;opacity:.8}
.nav{display:flex;background:#1a2535;overflow-x:auto;border-bottom:2px solid #0f3460}
.nav-btn{flex:none;padding:12px 20px;background:none;border:none;color:#888;cursor:pointer;font-size:13px;white-space:nowrap;border-bottom:3px solid transparent;transition:all .2s}
.nav-btn.active{color:white;border-bottom-color:#667eea}
.page{display:none;padding:15px}
.page.active{display:block}
.stats-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:15px}
.stat-card{background:white;border-radius:10px;padding:15px;text-align:center;box-shadow:0 2px 8px rgba(0,0,0,.1)}
.stat-num{font-size:22px;font-weight:700;color:#0f3460}
.stat-lbl{font-size:11px;color:#888;margin-top:3px}
.stat-sub{font-size:10px;color:#48bb78;margin-top:2px}
.card{background:white;border-radius:10px;padding:15px;margin-bottom:12px;box-shadow:0 2px 8px rgba(0,0,0,.1)}
.card h3{font-size:14px;color:#0f3460;margin-bottom:12px;border-bottom:2px solid #f0f4ff;padding-bottom:8px}
.field{margin-bottom:10px}
.field label{display:block;font-size:12px;font-weight:600;color:#555;margin-bottom:4px}
.field input,.field select,.field textarea{width:100%;padding:9px 12px;border:1.5px solid #e0e8ff;border-radius:7px;font-size:13px;font-family:inherit;direction:rtl;background:white;transition:border .2s}
.field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:#0f3460}
.field textarea{min-height:60px;resize:vertical}
.row2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px}
.total-box{background:#f0f4ff;border-radius:7px;padding:10px;text-align:center;margin:10px 0}
.total-box span{font-size:18px;font-weight:700;color:#0f3460}
.total-box p{font-size:11px;color:#888}
.btn-primary{width:100%;padding:13px;background:linear-gradient(135deg,#0f3460,#533483);color:white;border:none;border-radius:8px;font-size:14px;font-weight:700;cursor:pointer;margin-top:5px}
.btn-secondary{width:100%;padding:9px;background:white;color:#0f3460;border:2px solid #0f3460;border-radius:8px;font-size:13px;cursor:pointer;margin-top:6px}
.btn-danger{background:white;color:#e53e3e;border:1.5px solid #e53e3e;border-radius:6px;padding:5px 10px;font-size:12px;cursor:pointer}
.media-row{display:flex;gap:8px;margin:8px 0}
.mbtn{flex:1;padding:10px;border:2px dashed #c0c8e8;border-radius:7px;background:white;cursor:pointer;font-size:12px;color:#666;text-align:center}
.mbtn.rec{border-color:#e53e3e;color:#e53e3e;background:#fff5f5}
.mstatus{font-size:11px;color:#e53e3e;min-height:16px;margin-bottom:5px}
.ppreview{display:flex;flex-wrap:wrap;gap:5px;margin:5px 0}
.ppreview img{width:60px;height:60px;object-fit:cover;border-radius:6px;cursor:pointer;border:2px solid #e0e8ff}
.records-list{margin-top:10px}
.record-item{background:white;border-radius:9px;padding:13px;margin-bottom:9px;box-shadow:0 2px 6px rgba(0,0,0,.08);border-right:4px solid #667eea}
.record-item.مصروف{border-right-color:#e53e3e}
.record-item.دفعة{border-right-color:#48bb78}
.record-item.مهمة{border-right-color:#ed8936}
.record-item.ملاحظة{border-right-color:#667eea}
.ri-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:5px}
.ri-title{font-weight:700;font-size:13px;color:#222}
.ri-meta{display:flex;gap:5px;flex-wrap:wrap;margin-top:3px}
.badge{padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600}
.badge-red{background:#ffe5e5;color:#c53030}
.badge-green{background:#e8f8f0;color:#276749}
.badge-orange{background:#fff3e0;color:#c05621}
.badge-blue{background:#e8f0ff;color:#2b6cb0}
.badge-purple{background:#f0e8ff;color:#553c9a}
.ri-desc{font-size:12px;color:#666;margin-top:5px;line-height:1.4}
.ri-amount{font-size:15px;font-weight:700;color:#0f3460;margin-top:4px}
audio{width:100%;margin-top:6px;border-radius:5px}
.client-card{background:white;border-radius:10px;padding:15px;margin-bottom:10px;box-shadow:0 2px 8px rgba(0,0,0,.1);cursor:pointer;transition:all .2s}
.client-card:hover{box-shadow:0 4px 15px rgba(0,0,0,.15)}
.client-name{font-size:15px;font-weight:700;color:#0f3460}
.client-info{font-size:12px;color:#888;margin-top:3px}
.client-balance{display:flex;justify-content:space-between;margin-top:10px;padding-top:10px;border-top:1px solid #f0f4ff}
.bal-item{text-align:center}
.bal-num{font-size:14px;font-weight:700}
.bal-lbl{font-size:10px;color:#888;margin-top:2px}
.bal-red{color:#e53e3e}
.bal-green{color:#48bb78}
.bal-blue{color:#0f3460}
.search-box{width:100%;padding:10px 15px;border:1.5px solid #e0e8ff;border-radius:8px;font-size:13px;margin-bottom:12px;direction:rtl}
.client-detail-header{background:linear-gradient(135deg,#0f3460,#533483);color:white;padding:15px;border-radius:10px;margin-bottom:12px}
.bund-row{display:flex;justify-content:space-between;padding:8px 0;border-bottom:1px solid #f0f4ff;font-size:13px}
.bund-row:last-child{border-bottom:none}
.bund-name{color:#444}
.bund-amount{font-weight:700;color:#0f3460}
.export-btn{background:#48bb78;color:white;border:none;border-radius:7px;padding:10px 20px;font-size:13px;cursor:pointer;font-weight:600}
.filter-row{display:flex;gap:6px;overflow-x:auto;margin-bottom:12px;padding-bottom:5px}
.ftab{flex:none;padding:6px 14px;border:1.5px solid #e0e8ff;border-radius:15px;background:white;cursor:pointer;font-size:12px;color:#666;white-space:nowrap}
.ftab.active{background:#0f3460;color:white;border-color:#0f3460}
.empty{text-align:center;padding:40px 20px;color:#bbb}
.back-btn{background:none;border:none;color:white;font-size:14px;cursor:pointer;margin-bottom:8px;padding:0}
</style>
</head>
<body>

<div class="header">
  <h1>📊 NEW POINT Engineering</h1>
  <p>نظام الحسابات والمهام اليومية</p>
</div>

<div class="nav">
  <button class="nav-btn active" onclick="showPage('home')">🏠 الرئيسية</button>
  <button class="nav-btn" onclick="showPage('add')">➕ إضافة</button>
  <button class="nav-btn" onclick="showPage('clients')">👥 العملاء</button>
  <button class="nav-btn" onclick="showPage('records')">📋 السجلات</button>
</div>

<!-- الرئيسية -->
<div id="page-home" class="page active">
  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-num" id="st-total-exp">0</div>
      <div class="stat-lbl">إجمالي المصاريف</div>
      <div class="stat-sub" id="st-total-exp-sub">جنيه</div>
    </div>
    <div class="stat-card">
      <div class="stat-num" id="st-total-pay">0</div>
      <div class="stat-lbl">إجمالي المدفوعات</div>
      <div class="stat-sub" id="st-total-pay-sub">جنيه</div>
    </div>
    <div class="stat-card">
      <div class="stat-num" id="st-clients">0</div>
      <div class="stat-lbl">عدد العملاء</div>
    </div>
    <div class="stat-card">
      <div class="stat-num" id="st-records">0</div>
      <div class="stat-lbl">إجمالي التسجيلات</div>
    </div>
  </div>

  <div class="card">
    <h3>📅 آخر التسجيلات</h3>
    <div id="recent-list"><div class="empty">لا توجد تسجيلات بعد</div></div>
  </div>
</div>

<!-- إضافة تسجيل -->
<div id="page-add" class="page">
  <div class="card">
    <h3>➕ تسجيل جديد</h3>

    <div class="field">
      <label>نوع التسجيل</label>
      <select id="f-type" onchange="onTypeChange()">
        <option value="">-- اختر النوع --</option>
        <optgroup label="مالي">
          <option value="مصروف">💸 مصروف</option>
          <option value="دفعة">💰 دفعة واردة من العميل</option>
        </optgroup>
        <optgroup label="تشغيلي">
          <option value="مهمة">📝 مهمة</option>
          <option value="ملاحظة">📌 ملاحظة</option>
        </optgroup>
      </select>
    </div>

    <div class="field">
      <label>اسم العميل</label>
      <input type="text" id="f-client" placeholder="مثال: د. وائل أحمد" list="clients-list">
      <datalist id="clients-list"></datalist>
    </div>

    <div class="row2">
      <div class="field">
        <label>الحي</label>
        <input type="text" id="f-district" placeholder="حي 23">
      </div>
      <div class="field">
        <label>رقم القطعة</label>
        <input type="text" id="f-plot" placeholder="610">
      </div>
    </div>

    <div class="field">
      <label>التاريخ</label>
      <input type="date" id="f-date">
    </div>

    <!-- بنود المصروف -->
    <div id="expense-fields" style="display:none">
      <div class="field">
        <label>البند</label>
        <select id="f-bund">
          <option value="">-- اختر البند --</option>
          <option>حفر وردم</option>
          <option>خرسانة عادية</option>
          <option>حديد تسليح</option>
          <option>طوب أحمر</option>
          <option>أسمنت</option>
          <option>رمل وزلط</option>
          <option>خرسانة جاهزة</option>
          <option>بلاط ورخام</option>
          <option>أبواب وشبابيك</option>
          <option>أسقف معلقة</option>
          <option>عزل مائي</option>
          <option>كهرباء وإنارة</option>
          <option>سباكة وصرف</option>
          <option>دهانات وتشطيبات</option>
          <option>عمالة وتشييد</option>
          <option>إشراف هندسي</option>
          <option>مصروف متنوع</option>
        </select>
      </div>

      <div class="field">
        <label>المورد / المقاول</label>
        <input type="text" id="f-supplier" placeholder="مثال: الحاج محسن عمار" list="suppliers-list">
        <datalist id="suppliers-list">
          <option>الحاج محسن عمار</option>
          <option>عمر عزت</option>
          <option>عبد السلام خليفة - المتحدة</option>
          <option>العرب - سن ورمل</option>
          <option>أحمد الفنجري</option>
          <option>حمادة أبو يوسف</option>
        </datalist>
      </div>

      <div class="row3">
        <div class="field">
          <label>الكمية</label>
          <input type="number" id="f-qty" placeholder="0" oninput="calcTotal()">
        </div>
        <div class="field">
          <label>الوحدة</label>
          <select id="f-unit">
            <option>طن</option>
            <option>شيكارة</option>
            <option>م³</option>
            <option>م²</option>
            <option>متر</option>
            <option>عدد</option>
            <option>يوم</option>
            <option>مقطوعية</option>
          </select>
        </div>
        <div class="field">
          <label>سعر الوحدة</label>
          <input type="number" id="f-price" placeholder="0" oninput="calcTotal()">
        </div>
      </div>

      <div class="total-box">
        <p>الإجمالي</p>
        <span id="calc-total">0</span> جنيه
      </div>

      <div class="field">
        <label>طريقة الدفع</label>
        <select id="f-paymethod">
          <option>كاش</option>
          <option>تحويل بنكي</option>
          <option>شيك</option>
        </select>
      </div>
    </div>

    <!-- دفعة واردة -->
    <div id="payment-fields" style="display:none">
      <div class="field">
        <label>المبلغ المستلم</label>
        <input type="number" id="f-payment-amount" placeholder="0">
      </div>
      <div class="field">
        <label>طريقة الاستلام</label>
        <select id="f-payment-method">
          <option>كاش</option>
          <option>تحويل بنكي</option>
          <option>شيك</option>
        </select>
      </div>
    </div>

    <!-- مهمة -->
    <div id="task-fields" style="display:none">
      <div class="field">
        <label>عنوان المهمة</label>
        <input type="text" id="f-task-title" placeholder="مثال: متابعة صب السقف">
      </div>
      <div class="field">
        <label>الأولوية</label>
        <select id="f-priority">
          <option>عادي</option>
          <option>مهم</option>
          <option>عاجل</option>
        </select>
      </div>
    </div>

    <div class="field">
      <label>التفاصيل والملاحظات</label>
      <textarea id="f-desc" placeholder="اكتب أي تفاصيل إضافية..."></textarea>
    </div>

    <div class="media-row">
      <button class="mbtn" id="abtn" onclick="toggleAudio()">🎤 تسجيل صوتي</button>
      <label class="mbtn">📷 إضافة صور<input type="file" id="f-photos" accept="image/*" multiple style="display:none" onchange="handlePhotos(this)"></label>
    </div>
    <div class="mstatus" id="astatus"></div>
    <div class="ppreview" id="ppreview"></div>

    <button class="btn-primary" onclick="saveRecord()">💾 حفظ التسجيل</button>
    <button class="btn-secondary" onclick="clearForm()">مسح النموذج</button>
  </div>
</div>

<!-- العملاء -->
<div id="page-clients" class="page">
  <div id="clients-list-view">
    <input type="text" class="search-box" placeholder="🔍 ابحث عن عميل..." oninput="renderClients(this.value)">
    <div id="clients-container"></div>
  </div>

  <div id="client-detail-view" style="display:none">
    <button class="back-btn" style="color:#0f3460;margin-bottom:10px" onclick="showClientsList()">→ العودة للقائمة</button>
    <div id="client-detail-content"></div>
  </div>
</div>

<!-- السجلات -->
<div id="page-records" class="page">
  <div class="filter-row">
    <button class="ftab active" onclick="setFilter('all',this)">الكل</button>
    <button class="ftab" onclick="setFilter('مصروف',this)">مصاريف</button>
    <button class="ftab" onclick="setFilter('دفعة',this)">دفعات</button>
    <button class="ftab" onclick="setFilter('مهمة',this)">مهام</button>
    <button class="ftab" onclick="setFilter('ملاحظة',this)">ملاحظات</button>
  </div>
  <input type="text" class="search-box" placeholder="🔍 ابحث في السجلات..." oninput="renderRecords(currentFilter, this.value)">
  <div id="records-container"></div>
</div>

<script>
let records = JSON.parse(localStorage.getItem('np_v3') || '[]');
let currentFilter = 'all';
let mediaRecorder = null, audioChunks = [], curAudio = null, photos = [];

// إعداد أولي
document.getElementById('f-date').valueAsDate = new Date();

function showPage(p) {
  document.querySelectorAll('.page').forEach(x => x.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(x => x.classList.remove('active'));
  document.getElementById('page-' + p).classList.add('active');
  event.target.classList.add('active');
  if (p === 'home') renderHome();
  if (p === 'clients') renderClients();
  if (p === 'records') renderRecords(currentFilter);
}

function onTypeChange() {
  const t = document.getElementById('f-type').value;
  document.getElementById('expense-fields').style.display = t === 'مصروف' ? 'block' : 'none';
  document.getElementById('payment-fields').style.display = t === 'دفعة' ? 'block' : 'none';
  document.getElementById('task-fields').style.display = (t === 'مهمة' || t === 'ملاحظة') ? 'block' : 'none';
}

function calcTotal() {
  const qty = parseFloat(document.getElementById('f-qty').value) || 0;
  const price = parseFloat(document.getElementById('f-price').value) || 0;
  document.getElementById('calc-total').textContent = (qty * price).toLocaleString('ar-EG');
}

async function toggleAudio() {
  const b = document.getElementById('abtn'), s = document.getElementById('astatus');
  if (mediaRecorder && mediaRecorder.state === 'recording') {
    mediaRecorder.stop(); b.textContent = '🎤 تسجيل صوتي'; b.className = 'mbtn'; s.textContent = '';
  } else {
    try {
      const st = await navigator.mediaDevices.getUserMedia({audio: true});
      mediaRecorder = new MediaRecorder(st); audioChunks = [];
      mediaRecorder.ondataavailable = e => audioChunks.push(e.data);
      mediaRecorder.onstop = () => { curAudio = new Blob(audioChunks, {type: 'audio/webm'}); s.textContent = '✅ تم التسجيل'; st.getTracks().forEach(t => t.stop()); };
      mediaRecorder.start(); b.textContent = '⏹️ إيقاف'; b.className = 'mbtn rec'; s.textContent = '🔴 جاري التسجيل...';
    } catch(e) { s.textContent = '❌ تعذر الوصول للميكروفون'; }
  }
}

function handlePhotos(i) {
  photos = []; document.getElementById('ppreview').innerHTML = '';
  Array.from(i.files).forEach(f => {
    const r = new FileReader();
    r.onload = e => {
      photos.push(e.target.result);
      const img = document.createElement('img'); img.src = e.target.result;
      img.onclick = () => { photos = photos.filter(p => p !== e.target.result); img.remove(); };
      document.getElementById('ppreview').appendChild(img);
    };
    r.readAsDataURL(f);
  });
}

async function saveRecord() {
  const type = document.getElementById('f-type').value;
  const client = document.getElementById('f-client').value.trim();
  if (!type) { alert('اختر نوع التسجيل'); return; }
  if (!client) { alert('اكتب اسم العميل'); return; }

  let amount = 0, details = {};

  if (type === 'مصروف') {
    const qty = parseFloat(document.getElementById('f-qty').value) || 0;
    const price = parseFloat(document.getElementById('f-price').value) || 0;
    amount = qty * price;
    details = {
      bund: document.getElementById('f-bund').value,
      supplier: document.getElementById('f-supplier').value,
      qty, unit: document.getElementById('f-unit').value, price,
      paymethod: document.getElementById('f-paymethod').value
    };
  } else if (type === 'دفعة') {
    amount = parseFloat(document.getElementById('f-payment-amount').value) || 0;
    details = { paymethod: document.getElementById('f-payment-method').value };
  } else {
    details = {
      taskTitle: document.getElementById('f-task-title').value,
      priority: document.getElementById('f-priority').value
    };
  }

  let aud = null;
  if (curAudio) { const r = new FileReader(); aud = await new Promise(res => { r.onload = e => res(e.target.result); r.readAsDataURL(curAudio); }); }

  const rec = {
    id: Date.now(), type, client,
    district: document.getElementById('f-district').value,
    plot: document.getElementById('f-plot').value,
    date: document.getElementById('f-date').value,
    desc: document.getElementById('f-desc').value,
    amount, details, audio: aud,
    photos: [...photos],
    created: new Date().toLocaleString('ar-EG')
  };

  records.unshift(rec);
  localStorage.setItem('np_v3', JSON.stringify(records));
  updateClientsDatalist();
  alert('✅ تم الحفظ بنجاح');
  clearForm();
  renderHome();
}

function clearForm() {
  ['f-type','f-client','f-district','f-plot','f-bund','f-supplier','f-qty','f-price','f-payment-amount','f-task-title','f-desc'].forEach(id => { const el = document.getElementById(id); if(el) el.value = ''; });
  document.getElementById('f-date').valueAsDate = new Date();
  document.getElementById('ppreview').innerHTML = '';
  document.getElementById('astatus').textContent = '';
  document.getElementById('abtn').textContent = '🎤 تسجيل صوتي';
  document.getElementById('abtn').className = 'mbtn';
  document.getElementById('calc-total').textContent = '0';
  document.getElementById('expense-fields').style.display = 'none';
  document.getElementById('payment-fields').style.display = 'none';
  document.getElementById('task-fields').style.display = 'none';
  photos = []; curAudio = null;
  if (mediaRecorder && mediaRecorder.state === 'recording') mediaRecorder.stop();
}

function updateClientsDatalist() {
  const clients = [...new Set(records.map(r => r.client).filter(Boolean))];
  document.getElementById('clients-list').innerHTML = clients.map(c => `<option>${c}</option>`).join('');
}

function renderHome() {
  const expenses = records.filter(r => r.type === 'مصروف').reduce((s, r) => s + r.amount, 0);
  const payments = records.filter(r => r.type === 'دفعة').reduce((s, r) => s + r.amount, 0);
  const clients = new Set(records.map(r => r.client).filter(Boolean)).size;
  document.getElementById('st-total-exp').textContent = expenses.toLocaleString('ar-EG');
  document.getElementById('st-total-pay').textContent = payments.toLocaleString('ar-EG');
  document.getElementById('st-clients').textContent = clients;
  document.getElementById('st-records').textContent = records.length;
  const recent = records.slice(0, 5);
  document.getElementById('recent-list').innerHTML = recent.length ? recent.map(r => recordHTML(r)).join('') : '<div class="empty">لا توجد تسجيلات</div>';
}

function renderClients(search = '') {
  const clients = {};
  records.forEach(r => {
    if (!r.client) return;
    if (!clients[r.client]) clients[r.client] = { name: r.client, district: r.district, plot: r.plot, expenses: 0, payments: 0 };
    if (r.type === 'مصروف') clients[r.client].expenses += r.amount;
    if (r.type === 'دفعة') clients[r.client].payments += r.amount;
  });

  const list = Object.values(clients).filter(c => !search || c.name.includes(search));

  document.getElementById('clients-container').innerHTML = list.length ? list.map(c => {
    const balance = c.payments - c.expenses;
    return `<div class="client-card" onclick="showClientDetail('${c.name}')">
      <div class="client-name">${c.name}</div>
      <div class="client-info">${c.district || ''} ${c.plot ? '- قطعة ' + c.plot : ''}</div>
      <div class="client-balance">
        <div class="bal-item"><div class="bal-num bal-red">${c.expenses.toLocaleString('ar-EG')}</div><div class="bal-lbl">مصاريف</div></div>
        <div class="bal-item"><div class="bal-num bal-green">${c.payments.toLocaleString('ar-EG')}</div><div class="bal-lbl">مدفوع</div></div>
        <div class="bal-item"><div class="bal-num ${balance >= 0 ? 'bal-green' : 'bal-red'}">${Math.abs(balance).toLocaleString('ar-EG')}</div><div class="bal-lbl">${balance >= 0 ? 'زيادة' : 'متبقي'}</div></div>
      </div>
    </div>`;
  }).join('') : '<div class="empty">لا يوجد عملاء</div>';
}

function showClientDetail(name) {
  document.getElementById('clients-list-view').style.display = 'none';
  document.getElementById('client-detail-view').style.display = 'block';

  const clientRecs = records.filter(r => r.client === name);
  const expenses = clientRecs.filter(r => r.type === 'مصروف').reduce((s, r) => s + r.amount, 0);
  const payments = clientRecs.filter(r => r.type === 'دفعة').reduce((s, r) => s + r.amount, 0);
  const balance = payments - expenses;

  const bunds = {};
  clientRecs.filter(r => r.type === 'مصروف' && r.details.bund).forEach(r => {
    if (!bunds[r.details.bund]) bunds[r.details.bund] = 0;
    bunds[r.details.bund] += r.amount;
  });

  document.getElementById('client-detail-content').innerHTML = `
    <div class="client-detail-header">
      <div style="font-size:18px;font-weight:700">${name}</div>
      <div style="font-size:12px;opacity:.8;margin-top:3px">${clientRecs[0]?.district || ''} ${clientRecs[0]?.plot ? '- قطعة ' + clientRecs[0].plot : ''}</div>
      <div style="display:flex;gap:20px;margin-top:12px">
        <div><div style="font-size:18px;font-weight:700;color:#fc8181">${expenses.toLocaleString('ar-EG')}</div><div style="font-size:11px;opacity:.8">إجمالي المصاريف</div></div>
        <div><div style="font-size:18px;font-weight:700;color:#68d391">${payments.toLocaleString('ar-EG')}</div><div style="font-size:11px;opacity:.8">إجمالي المدفوع</div></div>
        <div><div style="font-size:18px;font-weight:700;color:${balance >= 0 ? '#68d391' : '#fc8181'}">${Math.abs(balance).toLocaleString('ar-EG')}</div><div style="font-size:11px;opacity:.8">${balance >= 0 ? 'زيادة' : 'متبقي للعميل'}</div></div>
      </div>
    </div>

    <div class="card">
      <h3>تفصيل المصاريف بالبنود</h3>
      ${Object.entries(bunds).map(([b, a]) => `<div class="bund-row"><span class="bund-name">${b}</span><span class="bund-amount">${a.toLocaleString('ar-EG')} ج</span></div>`).join('') || '<div style="color:#bbb;text-align:center;padding:10px">لا توجد مصاريف</div>'}
    </div>

    <div class="card">
      <h3>جميع التسجيلات</h3>
      ${clientRecs.map(r => recordHTML(r)).join('') || '<div class="empty">لا توجد تسجيلات</div>'}
    </div>
  `;
}

function showClientsList() {
  document.getElementById('clients-list-view').style.display = 'block';
  document.getElementById('client-detail-view').style.display = 'none';
}

function setFilter(f, btn) {
  currentFilter = f;
  document.querySelectorAll('.ftab').forEach(x => x.classList.remove('active'));
  btn.classList.add('active');
  renderRecords(f);
}

function renderRecords(filter = 'all', search = '') {
  let filtered = filter === 'all' ? records : records.filter(r => r.type === filter);
  if (search) filtered = filtered.filter(r => r.client?.includes(search) || r.desc?.includes(search) || r.details?.bund?.includes(search));
  document.getElementById('records-container').innerHTML = filtered.length ? filtered.map(r => recordHTML(r, true)).join('') : '<div class="empty">لا توجد سجلات</div>';
}

function recordHTML(r, showDel = false) {
  const badgeClass = r.type === 'مصروف' ? 'badge-red' : r.type === 'دفعة' ? 'badge-green' : r.type === 'مهمة' ? 'badge-orange' : 'badge-blue';
  return `<div class="record-item ${r.type}">
    <div class="ri-top">
      <div>
        <div class="ri-title">${r.client || ''} ${r.district ? '- ' + r.district : ''} ${r.plot ? '(ق' + r.plot + ')' : ''}</div>
        <div class="ri-meta">
          <span class="badge ${badgeClass}">${r.type}</span>
          ${r.details?.bund ? `<span class="badge badge-purple">${r.details.bund}</span>` : ''}
          ${r.details?.supplier ? `<span class="badge badge-blue">${r.details.supplier}</span>` : ''}
          <span style="font-size:11px;color:#aaa">${r.date}</span>
        </div>
      </div>
      ${showDel ? `<button class="btn-danger" onclick="deleteRecord(${r.id})">✕</button>` : ''}
    </div>
    ${r.amount ? `<div class="ri-amount">${r.amount.toLocaleString('ar-EG')} جنيه ${r.details?.qty ? `(${r.details.qty} ${r.details.unit} × ${r.details.price?.toLocaleString('ar-EG')} ج)` : ''}</div>` : ''}
    ${r.details?.taskTitle ? `<div class="ri-desc">📝 ${r.details.taskTitle} ${r.details?.priority ? '- ' + r.details.priority : ''}</div>` : ''}
    ${r.desc ? `<div class="ri-desc">${r.desc}</div>` : ''}
    ${r.audio ? `<audio controls src="${r.audio}"></audio>` : ''}
    ${r.photos?.length ? `<div class="ppreview">${r.photos.map(p => `<img src="${p}" onclick="window.open('${p}','_blank')">`).join('')}</div>` : ''}
  </div>`;
}

function deleteRecord(id) {
  if (confirm('حذف هذا التسجيل؟')) {
    records = records.filter(r => r.id !== id);
    localStorage.setItem('np_v3', JSON.stringify(records));
    renderRecords(currentFilter);
    renderHome();
  }
}

updateClientsDatalist();
renderHome();
</script>
</body>
</html>
